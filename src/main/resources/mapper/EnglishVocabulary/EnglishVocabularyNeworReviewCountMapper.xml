<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vocabularyassitant.mapper.EnglishVocabulary.EnglishVocabularyNeworReviewCountMapper">

    <select id="getMonthlyEnglishVocabularyNeworReviewCount"
            resultType="com.vocabularyassitant.entity.EnglishVocabularyNeworReviewCount">
        select *
        from EnglishVocabularyNeworReviewCountTable
        where uId = #{uId}
        and DATE_FORMAT(pDate, '%Y-%m') = #{yearMonth}
        order by pDate asc
    </select>

</mapper>
