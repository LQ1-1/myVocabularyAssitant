<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vocabularyassitant.mapper.InviteCodeMapper">

    <insert id="addInviteCode"
            parameterType="com.vocabularyassitant.entity.InviteCode">
        insert into InviteCodeTable(uId, iOwnReferralCode, iAppliedReferralCode)values(
        #{uId}, #{iOwnReferralCode}, #{iAppliedReferralCode}
        );
    </insert>

    <select id="checkInviteCodeValidity"
            parameterType="string">
        select count(*) from InviteCodeTable where iOwnReferralCode=#{inviteCode};
    </select>

</mapper>