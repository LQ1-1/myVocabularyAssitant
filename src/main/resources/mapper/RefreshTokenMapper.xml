<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vocabularyassitant.mapper.RefreshTokenMapper">

    <resultMap id="RefreshTokenMap" type="com.vocabularyassitant.entity.RefreshToken">
        <id property="rId" column="rId"/>
        <result property="uId" column="uId"/>
        <result property="refreshTokenHash" column="refreshTokenHash"/>
        <result property="deviceId" column="deviceId"/>
        <result property="deviceType" column="deviceType"/>
        <result property="issuedAt" column="issuedAt"/>
        <result property="expiresAt" column="expiresAt"/>
        <result property="lastRefreshedAt" column="lastRefreshedAt"/>
        <result property="revokedAt" column="revokedAt"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="createdAt"/>
        <result property="updatedAt" column="updatedAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.vocabularyassitant.entity.RefreshToken">
        insert into RefreshTokenTable (
            rId,
            uId,
            refreshTokenHash,
            deviceId,
            deviceType,
            issuedAt,
            expiresAt,
            lastRefreshedAt,
            status,
            createdAt,
            updatedAt
        ) values (
            #{rId},
            #{uId},
            #{refreshTokenHash},
            #{deviceId},
            #{deviceType},
            #{issuedAt},
            #{expiresAt},
            #{lastRefreshedAt},
            #{status},
            now(),
            now()
        )
    </insert>

    <select id="findByRefreshTokenHash" resultMap="RefreshTokenMap">
        select *
        from RefreshTokenTable
        where refreshTokenHash = #{refreshTokenHash}
        limit 1
    </select>

    <update id="updateRefreshTokenByRId" parameterType="com.vocabularyassitant.entity.RefreshToken">
        update RefreshTokenTable
        set refreshTokenHash = #{refreshTokenHash},
            expiresAt = #{expiresAt},
            lastRefreshedAt = #{lastRefreshedAt},
            updatedAt = now()
        where rId = #{rId}
    </update>

    <update id="revokeByRId">
        update RefreshTokenTable
        set status = 2,
            revokedAt = #{revokedAt},
            updatedAt = now()
        where rId = #{rId}
    </update>
</mapper>
